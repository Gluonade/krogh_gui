{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Krogh GUI",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "${workspaceFolder}/app.py"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build"
        },
        {
            "label": "Run Synthetic Validation",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "${workspaceFolder}/run_synthetic_validation.py"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}